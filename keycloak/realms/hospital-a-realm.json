{
  "realm": "hospital-a",
  "enabled": true,
  "displayName": "Hospital A - City General",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "System administrator - full platform control",
        "composite": false
      },
      {
        "name": "PROVIDER",
        "description": "Healthcare provider organization - manages staff",
        "composite": false
      },
      {
        "name": "THERAPIST",
        "description": "Conducts therapy sessions with patients",
        "composite": false
      },
      {
        "name": "PHYSICIAN",
        "description": "Supervises treatment plans, prescribes medication",
        "composite": false
      },
      {
        "name": "NURSE",
        "description": "Assists with patient care operations",
        "composite": false
      },
      {
        "name": "PATIENT",
        "description": "End user - views own appointments and health data",
        "composite": false
      }
    ],
    "client": {
      "platform-backend": [
        {
          "name": "READ_PATIENT",
          "description": "Permission to read patient records"
        },
        {
          "name": "UPDATE_PATIENT",
          "description": "Permission to update patient records"
        },
        {
          "name": "CREATE_PATIENT",
          "description": "Permission to create new patients"
        },
        {
          "name": "DELETE_PATIENT",
          "description": "Permission to delete patient records"
        },
        {
          "name": "MANAGE_STAFF",
          "description": "Permission to manage staff members"
        },
        {
          "name": "MANAGE_FACILITY",
          "description": "Permission to manage facilities"
        },
        {
          "name": "VIEW_REPORTS",
          "description": "Permission to view analytics and reports"
        },
        {
          "name": "MANAGE_PHARMACY",
          "description": "Permission to manage pharmacy stock"
        }
      ],
      "platform-frontend": []
    }
  },
  "groups": [
    {
      "name": "administrators",
      "realmRoles": ["ADMIN"]
    },
    {
      "name": "providers",
      "realmRoles": ["PROVIDER"]
    },
    {
      "name": "clinical-staff",
      "subGroups": [
        {
          "name": "therapists",
          "realmRoles": ["THERAPIST"]
        },
        {
          "name": "physicians",
          "realmRoles": ["PHYSICIAN"]
        },
        {
          "name": "nurses",
          "realmRoles": ["NURSE"]
        }
      ]
    },
    {
      "name": "patients",
      "realmRoles": ["PATIENT"]
    }
  ],
  "clients": [
    {
      "clientId": "platform-backend",
      "name": "Platform Backend Services",
